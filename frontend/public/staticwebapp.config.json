{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/games/*", "/assets/*", "*.{css,js,svg,png,jpg,ico,json}"]
  },
  "mimeTypes": {
    ".js": "application/javascript",
    ".mjs": "application/javascript",
    ".json": "application/json",
    ".css": "text/css",
    ".html": "text/html",
    ".svg": "image/svg+xml",
    ".png": "image/png",
    ".jpg": "image/jpeg",
    ".ico": "image/x-icon",
    ".wasm": "application/wasm"
  }
}
